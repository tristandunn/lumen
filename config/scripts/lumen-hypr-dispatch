#!/usr/bin/env bash

set -euo pipefail

declare -A SHORTCUTS=(
  [cs2:tab-close]="noop"
  [default:copy]="SHIFT+CONTROL,C"
  [default:paste]="SHIFT+CONTROL,V"
  [default:save]="CONTROL,S"
  [default:tab-close]="killactive"
  [default:toggle-float]="toggle-float"
  [firefox:copy]="CONTROL,C"
  [firefox:paste]="CONTROL,V"
  [firefox:reload]="CONTROL,R"
  [firefox:select-all]="CONTROL,A"
  [firefox:tab-close]="CONTROL,W"
  [firefox:tab-goto-number]="ALT"
  [firefox:tab-new]="CONTROL,T"
  [firefox:tab-next]="CONTROL,Next"
  [firefox:tab-previous]="CONTROL,Prior"
  [kitty:tab-close]="SHIFT+CONTROL,W"
  [kitty:tab-goto-number]="CONTROL+ALT"
  [kitty:tab-new]="SHIFT+CONTROL,T"
  [kitty:tab-next]="SHIFT+CONTROL,RIGHT"
  [kitty:tab-previous]="SHIFT+CONTROL,LEFT"
  [steam:tab-close]="noop"
)

action="${1}"
param="${2:-}"
class=$(hyprctl activewindow -j | jq -r '.class')
address="0x$(hyprctl activewindow | head -n 1 | awk '{print $2}')"
shortcut="${SHORTCUTS[${class}:${action}]:-${SHORTCUTS[default:${action}]}}"

if [[ -z "${shortcut}" ]]; then
  exit 1
elif [[ "${shortcut}" == "noop" ]]; then
  exit 0
elif [[ "${shortcut}" == "killactive" ]]; then
  hyprctl dispatch 'hl.dsp.window.close()'
elif [[ "${shortcut}" == "toggle-float" ]]; then
  window_info=$(hyprctl activewindow -j)
  floating=$(echo "${window_info}" | jq -r '.floating')
  workspace=$(echo "${window_info}" | jq -r '.workspace.name')
  monitor=$(echo "${window_info}" | jq -r '.monitor')

  hyprctl dispatch 'hl.dsp.window.float({ action = "toggle" })'
  hyprctl dispatch "hl.dsp.window.move({ workspace = \"${workspace}\" })"

  if [[ "${floating}" == "false" ]]; then
    # The Lua resize dispatcher takes pixels, not a percentage, so compute 80%
    # of the monitor's logical resolution (physical size divided by its scale).
    read -r width height < <(
      hyprctl monitors -j |
        jq -r --argjson m "${monitor}" \
          '.[] | select(.id == $m) | "\((.width / .scale * 0.8) | floor) \((.height / .scale * 0.8) | floor)"'
    )

    hyprctl dispatch "hl.dsp.window.resize({ x = ${width}, y = ${height}, relative = false })"
    hyprctl dispatch 'hl.dsp.window.center()'
  fi
else
  if [[ -n "${param}" ]]; then
    mods="${shortcut}"
    key="${param}"
  else
    mods="${shortcut%%,*}"
    key="${shortcut#*,}"
  fi

  hyprctl dispatch "hl.dsp.send_shortcut({ mods = \"${mods}\", key = \"${key}\", window = \"address:${address}\" })"
fi
