#!/usr/bin/env bash

set -euo pipefail

if [[ "${1:-}" == "raise" ]]; then
  arg="+5%"
elif [[ "${1:-}" == "lower" ]]; then
  arg="-5%"
else
  echo "Usage: lumen-brightness-control <raise|lower>" >&2
  exit 1
fi

output=""
for device in /dev/usb/hiddev*; do
  result=$(sudo asdcontrol --silent "${device}" -- "${arg}" 2>&1) || true
  if [[ "${result}" == *"BRIGHTNESS"* ]]; then
    output="${result}"
    break
  fi
done

if [[ -z "${output}" ]]; then
  echo "No USB monitor found." >&2
  exit 1
fi

brightness=$(echo "${output}" | grep -oP 'BRIGHTNESS=\K\d+')
percentage=$(((brightness - 400) * 100 / 59600))
progress=$(awk "BEGIN {printf \"%.2f\", ${percentage} / 100}")

swayosd-client --custom-icon "display-brightness-symbolic" \
  --custom-progress "${progress}" \
  --custom-progress-text "${percentage}%"
